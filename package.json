{
  "name": "dukaanbench",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "web:dev": "vite --host 127.0.0.1 --port 5175 --strictPort",
    "server:dev": "tsx server/index.ts",
    "server:start": "node --experimental-sqlite --import tsx server/index.ts",
    "start": "npm run server:start",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "tsx --test src/arena/arena-mobile-layout.test.ts src/base-path.test.ts",
    "test:arena-mobile": "KIRANA_BASE_PATH=/dukaanbench npm run build && npm run test && KIRANA_BASE_PATH=/dukaanbench node scripts/verify-arena-mobile.mjs --bases=local,prod"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@types/node": "^26.0.0",
    "fastify": "^5.8.5",
    "phaser": "^4.2.0",
    "tsx": "^4.22.4"
  }
}
